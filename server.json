{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Samik081/mcp-komodo",
  "version": "0.5.5",
  "title": "Komodo MCP Server",
  "description": "Manage Komodo through AI assistants",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/Samik081/mcp-komodo",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@samik081/mcp-komodo",
      "version": "0.5.5",
      "runtimeHint": "node",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KOMODO_URL",
          "description": "URL of the Komodo instance (e.g. https://komodo.example.com)",
          "isRequired": true
        },
        {
          "name": "KOMODO_API_KEY",
          "description": "Komodo API key",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "KOMODO_API_SECRET",
          "description": "Komodo API secret",
          "isRequired": true,
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/samik081/mcp-komodo:0.5.5",
      "version": "0.5.5",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KOMODO_URL",
          "description": "URL of the Komodo instance (e.g. https://komodo.example.com)",
          "isRequired": true
        },
        {
          "name": "KOMODO_API_KEY",
          "description": "Komodo API key",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "KOMODO_API_SECRET",
          "description": "Komodo API secret",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
